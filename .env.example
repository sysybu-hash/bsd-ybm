# מחרוזת חיבור ל-PostgreSQL (חובה ל-Prisma / Next).
# Next.js טוען גם .env.local — מומלץ לשים שם את DATABASE_URL בפיתוח.
# פקודות Prisma בפרויקט (npm run db:push וכו') טוענות אוטומטית מ-.env.local.
# אם מריצים npx prisma ישירות בלי הסקריפט — הוסף DATABASE_URL גם ל-.env או השתמש ב-npm run db:push.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bsd_ybm?schema=public"
# חיבור ישיר ל-Postgres (חובה ל־Prisma כשיש pooler ב-Neon). בפיתוח מקומי ללא Neon: שכפל את DATABASE_URL.
# ב-Neon: Connection details → כבה "Connection pooling" והעתק URL לכאן (host בלי -pooler).
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/bsd_ybm?schema=public"
# אוטומטי מ-pooler: npm run neon:ensure-direct (יוצר DIRECT_URL מ-DATABASE_URL של Neon)

# ═══════════════════════════════════════════════════════════════════════════
# Neon + Vercel + Firebase — סדר עבודה מומלץ (פרודקשן)
# ═══════════════════════════════════════════════════════════════════════════
#
# 1) Neon (neon.tech)
#    - צרו פרויקט Postgres; העתיקו Connection string ל־«Transaction» או «Pooled».
#    - ל־Vercel Serverless מומלץ Pooled (בממשק Neon: Connection string → כיבוי
#      «Direct connection» או host שמסתיים ב־-pooler / כתובת pooler).
#    - הוסיפו ?sslmode=require אם לא מופיע.
#    - שימו את אותה מחרוזת ב־DATABASE_URL ב־.env.local וב־Vercel (Production).
#    - סנכרון סכמה ל־Neon: npm run db:push (מקומית מול DATABASE_URL של Neon)
#      או prisma migrate deploy בסביבת CI.
#    - אם prisma מחזיר P1001 מהמחשב אבל SQL Editor ב-Neon עובד: הרשת/פיירוול/VPN חוסמים
#      פורט 5432 — נסה רשת אחרת, בלי VPN, או עדכן את DATABASE_URL מה־Connection details
#      (הוסט עשוי להשתנות). עד אז: הרץ את prisma/migrations/neon_apply_construction_full.sql
#      ב־Neon → SQL Editor (מסנכרן industry + constructionTrade בלי טרמינל).
#
# 2) Vercel (vercel.com)
#    - חיבור דומיין (bsd-ybm.co.il) ו־Environment Variables לסביבת Production.
#    - דחיפה מקומית מ־.env.local (כל שורה לא ריקה):  npm run vercel:env:push
#    - חבילת מינימום (אימות + DB + AI + OAuth):     npm run vercel:env:push:stack
#    - משיכה מהענן לקובץ:                            npm run vercel:env:pull
#    - מחיקת כל המשתנים בענן + דחיפה מחדש מ־.env.local (זהירות!): npm run vercel:env:resync
#    - בדיקה לפני פריסה:                             npm run check:deploy
#    - פריסת פרודקשן:                                npm run vercel:deploy:prod
#    - אינטגרציית Vercel↔Neon: אם הותקן מהדשבורד, וודאו ש־Prisma משתמש ב־DATABASE_URL
#      (לפעמים המשתנה נקרא POSTGRES_URL — שכפלו ל־DATABASE_URL או ערכו prisma/schema).
#
# 3) Firebase (אם משתמשים בסקריפטים / Admin SDK)
#    - Console → Project settings → כל ה־NEXT_PUBLIC_* לצד לקוח.
#    - Service account JSON → base64 לשורה אחת → FIREBASE_SERVICE_ACCOUNT_BASE64 (ב־Vercel: Sensitive).
#    - Firestore: אם יש database שני, הגדירו NEXT_PUBLIC_FIREBASE_DATABASE_ID / FIREBASE_DATABASE_ID.
#
# ═══════════════════════════════════════════════════════════════════════════

# --- NextAuth / Vercel (פרודקשן) ---
# בפיתוח מקומי: http://localhost:3000
# בפרודקשן (bsd-ybm.co.il): חובה ש-NEXTAUTH_URL ו-AUTH_URL יהיו כתובת האתר המלאה עם https
# NEXTAUTH_URL="https://bsd-ybm.co.il"
# AUTH_URL="https://bsd-ybm.co.il"
# NEXTAUTH_SECRET="..."  # או AUTH_SECRET
#
# חסימת התחברות (אופציונלי): מיילים מופרדים בפסיקים — גם אם המשתמש ACTIVE ב-DB לא יוכל להיכנס
# (Gmail: נרמול נקודות ב-local חלק מ־canonicalizeLoginEmail)
# LOGIN_BLOCKED_EMAILS="guard@example.com,other@example.com"
#
# רשימת התרה (אופציונלי): אם מוגדר — רק המיילים האלה יכולים להתחבר (Google + סיסמה).
# LOGIN_ALLOWLIST_EMAILS מקבל עדיפות; אחרת נבדק ALLOWED_LOGIN_EMAILS (תאימות).
# דוגמה לבעלים יחיד: LOGIN_ALLOWLIST_EMAILS="sysybu@gmail.com"
# LOGIN_ALLOWLIST_EMAILS=""
# ALLOWED_LOGIN_EMAILS=""
#
# סקריפט ניקוי DB (מוחק כל המשתמשים חוץ מבעלים + מנקה נתוני עסק): RESET_KEEP_OWNER_EMAIL או מייל ראשון מ-LOGIN_ALLOWLIST_EMAILS
# npm run db:wipe:keep-owner -- --dry-run
# npm run db:wipe:keep-owner -- --yes
# RESET_KEEP_OWNER_EMAIL="sysybu@gmail.com"

# --- Firebase (צד לקוח + סקריפטים) ---
# יש לשכפל את אותם ערכים ל-Vercel → Environment Variables (כל המפתחות NEXT_PUBLIC_* + שרת)
# NEXT_PUBLIC_FIREBASE_API_KEY=""
# NEXT_PUBLIC_FIREBASE_APP_ID=""
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=""   # נדרש לסקריפט firebase-admin אם אין service account
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
# NEXT_PUBLIC_FIREBASE_DATABASE_ID=""
# FIREBASE_DATABASE_ID=""
# FIREBASE_SERVICE_ACCOUNT_BASE64=""   # אופציונלי — לסקריפטים / Admin SDK

# אופציונלי: אימייל להצגה במסמכים משפטיים (פומבי)
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL="yb@bsd-ybm.co.il"
# שם ישות משפטית מלא (מוצג במדיניות פרטיות)
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=""
# ח.פ. / עוסק מורשה (אופציונלי)
# NEXT_PUBLIC_LEGAL_ENTITY_ID=""
# כתובת רשומה — חשוב ל-GDPR / שקיפות
# NEXT_PUBLIC_LEGAL_REGISTERED_ADDRESS="רחוב, עיר, מדינה"
# נציג GDPR באיחוד (מאמר 27) — רק אם חל; אחרת עדכן ידנית במסמך
# NEXT_PUBLIC_EU_REPRESENTATIVE=""
#
# Google Analytics 4 — רק אם מפעילים; נטען רק אחרי הסכמת אנליטיקה בבאנר
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# נעילת ניהול (Steel Lock): בעל פלטפורמה יחיד — ברירת מחדל sysybu@gmail.com (lib/is-admin.ts).
# אם חשבון Google/DB נרשם עם מייל אחר (למשל טעות הקלדה), הגדר כאן את המייל המדויק:
# STEEL_ADMIN_EMAIL="sysybu@gmail.com"
# PLATFORM_DEVELOPER_EMAILS — הוסר מהלוגיקה; לא משפיע על גישה (נשאר רק לתיעוד ישן אם קיים).

# מודל Gemini (Google AI Studio). אם מתקבל 404 על המודל — עדכן לפי התיעוד הרשמי.
# ברירת מחדל בקוד: gemini-2.5-flash (2.0-flash אינו זמין לחשבונות חדשים)
# GEMINI_MODEL="gemini-2.5-flash"
#
# ניתוח CRM (/dashboard/crm): ברירת מחדל למנוי FREE — מודל מהיר/זול:
# CRM_ANALYSIS_GEMINI_MODEL="gemini-2.5-flash"
# ל-PRO / ENTERPRISE / BUSINESS או כשמבצע הניתוח הוא SUPER_ADMIN — אופציונלי מודל חזק יותר:
# PREMIUM_GEMINI_MODEL="gemini-2.5-pro"

# ספקי AI נוספים (אופציונלי) — מרכז AI בדשבורד
# GOOGLE_GENERATIVE_AI_API_KEY=""
# או GEMINI_API_KEY=""
# OPENAI_API_KEY=""
# OPENAI_VISION_MODEL="gpt-4o"
# OPENAI_CHAT_MODEL="gpt-4o-mini"
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
# GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# --- אימיילים (Resend ו/או SMTP) ---
# RESEND_API_KEY=""   # מומלץ — אותו ספק כמו send-credentials
# MAIL_FROM="BSD-YBM <system@bsd-ybm.co.il>"
# חלופה: Nodemailer + SMTP
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""

# --- אימות דומיין (אחרי קבלת טוקנים מגוגל / בינג / פייסבוק וכו׳) ---
# כתובת קנונית לפרודקשן (למטא־תגיות ו-Open Graph)
# NEXT_PUBLIC_SITE_URL="https://www.bsd-ybm.co.il"
#
# מטא — Google Search Console (תוכן הטוקן בלבד, ללא תגית HTML)
# SITE_VERIFICATION_GOOGLE=""
# או: GOOGLE_SITE_VERIFICATION=""  (תואם ל-SITE_VERIFICATION_GOOGLE)
# Bing Webmaster — תוכן מטא msvalidate.01
# SITE_VERIFICATION_BING=""
# SITE_VERIFICATION_YAHOO=""
# SITE_VERIFICATION_YANDEX=""
# SITE_VERIFICATION_FACEBOOK=""
# SITE_VERIFICATION_PINTEREST=""
# ספק מתאים אחר (שם מטא + תוכן)
# SITE_VERIFICATION_META_NAME="custom-verification"
# SITE_VERIFICATION_META_CONTENT=""
#
# קבצים סטטיים: ראה public/domain-verification/README.txt

# --- PayPal ---
# א. מפעיל הפלטפורמה (רק אתה — לא מוצג ללקוחות ארגונים): דף אדמין / חדר מצב
# PLATFORM_PAYPAL_MERCHANT_EMAIL="you@example.com"
# PLATFORM_PAYPAL_ME_SLUG="YourPaypalMe"
#
# ב. כל ארגון בנפרד (לקוחות קצה משלמים לעסק): Dashboard › הגדרות › מנויים (שדות ב-DB, לא ENV)
#
# ג. PayPal Live — כפתורי תשלום למנוי (דף מנויים): מזהה ציבורי + סוד בשרת בלבד
# NEXT_PUBLIC_PAYPAL_CLIENT_ID="..."   # Live Client ID מ-PayPal Developer Dashboard
# PAYPAL_CLIENT_SECRET="..."           # Live Secret — לעולם לא בקוד לקוח
# PAYPAL_ENV="live"                    # או sandbox לבדיקות
# (אופציונלי) PAYPAL_CLIENT_ID="..."  # אם רוצים מזהה שרת נפרד מ-NEXT_PUBLIC
#
# סנכרון לשרת (Vercel Production) אחרי עדכון ב-.env.local:
#   npm run vercel:env:push -- --only=NEXT_PUBLIC_PAYPAL_CLIENT_ID,PAYPAL_CLIENT_SECRET,PAYPAL_ENV,PLATFORM_PAYPAL_MERCHANT_EMAIL
# ואז פריסה: npm run vercel:deploy:prod
# (נדרש: npx vercel login + פרויקט מקושר)
#
# --- PayPlus (קישור תשלום + webhook) ---
# PAYPLUS_API_KEY=""
# PAYPLUS_SECRET_KEY=""
# PAYPLUS_PAYMENT_PAGE_UID=""
# אופציונלי: סביבת בדיקות — https://restapidev.payplus.co.il/api/v1.0
# PAYPLUS_API_URL="https://restapidev.payplus.co.il/api/v1.0"
# אופציונלי: אימות קריאות ל־/api/webhooks/payplus (Bearer או כותרת x-payplus-token)
# PAYPLUS_WEBHOOK_SECRET=""
#
# סימולציית תשלום (רק אם PayPlus לא מוגדר): בפרודקשן אסור! אפשר true רק לבדיקה מבוקרת
# PAYPLUS_ALLOW_MOCK="true"
