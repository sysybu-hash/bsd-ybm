{
  "name": "bsd-ybm-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "node scripts/prisma-generate-safe.mjs && next build",
    "start": "next start",
    "test": "jest",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:execute:subscription-v2": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/manual_subscription_v2.sql --schema prisma/schema.prisma",
    "db:execute:rename-scans": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/rename_scans_remaining_and_invitations.sql --schema prisma/schema.prisma",
    "db:execute:org-invite": "dotenv -e .env.local -- prisma db execute --file prisma/migrations/add_organization_invite.sql --schema prisma/schema.prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "broadcast:inapp": "dotenv -e .env.local -- node scripts/broadcast-inapp.mjs",
    "db:wipe:keep-owner": "dotenv -e .env.local -- node scripts/wipe-postgres-keep-owner.mjs",
    "db:delete-user": "dotenv -e .env.local -- node scripts/delete-user-by-email.mjs",
    "vercel:env:pull": "vercel env pull .env.vercel.pull --yes",
    "vercel:env:push": "node scripts/vercel-push-env-from-local.mjs",
    "vercel:env:push:core": "node scripts/vercel-push-env-from-local.mjs --only=DATABASE_URL,NEXTAUTH_SECRET,NEXTAUTH_URL,GOOGLE_GENERATIVE_AI_API_KEY,NEXT_PUBLIC_VAT_RATE",
    "vercel:env:push:stack": "node scripts/vercel-push-env-from-local.mjs --only=DATABASE_URL,NEXTAUTH_SECRET,NEXTAUTH_URL,AUTH_URL,GOOGLE_CLIENT_ID,GOOGLE_CLIENT_SECRET,GOOGLE_GENERATIVE_AI_API_KEY,NEXT_PUBLIC_SITE_URL",
    "vercel:deploy:prod": "vercel deploy --prod --yes",
    "check:deploy": "node scripts/check-neon-vercel-prereqs.mjs",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "tutorials:encode": "node scripts/generate-tutorial-videos.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "@google-cloud/documentai": "^9.6.0",
    "@google/generative-ai": "^0.24.1",
    "@headlessui/react": "^2.2.9",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@next/eslint-plugin-next": "^16.2.2",
    "@paypal/react-paypal-js": "^9.1.0",
    "@prisma/client": "^6.1.0",
    "@react-pdf/renderer": "^4.3.2",
    "@tanstack/react-query": "^5.95.2",
    "@types/leaflet": "^1.9.21",
    "ai": "^6.0.140",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.446.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.10",
    "nodemailer": "^7.0.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.72.0",
    "react-signature-canvas": "^1.0.6",
    "recharts": "^2.15.4",
    "resend": "^4.8.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "overrides": {
    "effect": ">=3.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "ts-jest": "^29.4.9",
    "typescript": "^5.6.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not IE 11",
      "Safari >= 14",
      "iOS >= 14",
      "Firefox ESR"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
