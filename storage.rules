rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /** Company logo uploads — admins only (Firestore membership check). */
    match /companies/{companyId}/assets/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
