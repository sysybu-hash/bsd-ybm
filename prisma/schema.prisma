generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Server-side log row for POST /api/sync (DB + Meckano + pipeline snapshot).
model SyncRun {
  id            String   @id @default(cuid())
  ok            Boolean
  message       String?
  dbStatus      String?
  meckanoStatus String?
  pipelineJson  Json?
  createdAt     DateTime @default(now())

  @@index([createdAt])
}
