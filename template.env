# =============================================================================
# BSD-YBM AI Solutions — template.env (copy to .env.local, fill values)
# =============================================================================
# Never commit .env.local. Server-only secrets must NOT use NEXT_PUBLIC_ prefix.

# --- Site (production) ---
NEXT_PUBLIC_SITE_URL=https://www.bsd-ybm.co.il
NEXT_PUBLIC_API_URL=https://www.bsd-ybm.co.il/api
NEXT_PUBLIC_USE_API_AUTH=true
# Optional: mailto on landing “יצירת קשר”
# NEXT_PUBLIC_CONTACT_EMAIL=sysybu@gmail.com

# --- Platform admins (comma-separated; integration key matrix + Admin Verified badge) ---
# Falls back to sysybu@gmail.com, jbuildgca@gmail.com, chaimad@gmail.com if unset.
NEXT_PUBLIC_ADMIN_EMAILS=sysybu@gmail.com,jbuildgca@gmail.com,chaimad@gmail.com

# --- Database (Neon / Prisma) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Firebase (client-safe) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional named database
NEXT_PUBLIC_FIREBASE_DATABASE_ID=

# --- Google OAuth (server + public client id for reference) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Auth / API signing (server-only) ---
JWT_SECRET=

# --- Phase 36 — Sentinel cron + Owner AI Coder (server-only) ---
# Vercel Cron sends: Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=
# Prefer Anthropic; fallback OpenAI (see src/lib/sentinel/llm.ts)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Owner AI Command Terminal (/owner-zone/terminal) — structured JSON via AI SDK (default gpt-4o)
OPENAI_TERMINAL_MODEL=gpt-4o
# Optional: push proposed .diff to new hotfix branch (classic PAT: repo scope)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_DEFAULT_BRANCH=main
# When true WITH GITHUB_* + HIGH confidence from AI, Sentinel cron pushes a patch file
SENTINEL_AUTO_PUSH=false

# --- AI: server-only (do not expose to browser) ---
GEMINI_API_KEY=
MINDSTUDIO_API_KEY=
MINDSTUDIO_WORKFLOW_ID=

# --- Meckano (server-only; per-tenant keys may live in Firestore) ---
MECKANO_API_KEY=

# --- Document AI (server-only; used by API routes) ---
GOOGLE_DOCUMENT_AI_KEY=
GOOGLE_DOCUMENT_AI_PROCESSOR=
AZURE_DOCUMENT_AI_KEY=
AZURE_DOCUMENT_AI_ENDPOINT=

# --- Optional: other LLM keys (server-only; chat API uses these) ---
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Legacy: NEXT_PUBLIC_GROQ_* / NEXT_PUBLIC_OPENROUTER_* still read as fallback — migrate off them.

# --- Email (Resend / SMTP) — verify domain in Resend for production sends ---
EMAIL_FROM=BSD-YBM AI Solutions <no-reply@bsd-ybm.co.il>
# Reply-To on all transactional mail (Phase 26.1). Defaults to sysybu@gmail.com if unset.
# EMAIL_REPLY_TO=sysybu@gmail.com
# RESEND_API_KEY=
# --- SMTP (Phase 26.1 — /api/send-invite & transactional mail). Used when EMAIL_SERVER_HOST is set.
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_SECURE=false
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=
# Optional display name for invites if Firestore has no displayName:
# INVITE_DEFAULT_INVITER_NAME=יוחנן בוקשפן

# --- Phase 15.6: Google Drive → OCR archive index (POST /api/archive/ingest-drive) ---
# DRIVE_SYNC_WEBHOOK_SECRET=

# --- Phase 15.5: e-sign / WhatsApp (contract signed → contractor alert) ---
# Optional Meta WhatsApp Cloud API. If unset, server logs only.
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# WHATSAPP_CLOUD_API_VERSION=v21.0
# Per company doc: contractNotifyPhoneE164 (e.g. +972501234567) on companies/{companyId}

# --- Firebase Admin Storage (signed PDF upload; optional override) ---
# FIREBASE_STORAGE_BUCKET=

# --- Media: optional embed for “Live Field Tour” on dashboard ---
NEXT_PUBLIC_FIELD_TOUR_VIDEO_URL=

# --- Calendar default view hint ---
NEXT_PUBLIC_DEFAULT_CALENDAR=hebrew
